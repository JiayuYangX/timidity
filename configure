  as_fn_error $? "conditional \"ENABLE_NETWORK\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
fi
if test -z "${ENABLE_SOUND_SPEC_TRUE}" && test -z "${ENABLE_SOUND_SPEC_FALSE}"; then
  as_fn_error $? "conditional \"ENABLE_SOUND_SPEC\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
fi
if test -z "${ENABLE_WRD_TRUE}" && test -z "${ENABLE_WRD_FALSE}"; then
  as_fn_error $? "conditional \"ENABLE_WRD\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
fi
if test -z "${W32G_GUI_TRUE}" && test -z "${W32G_GUI_FALSE}"; then
  as_fn_error $? "conditional \"W32G_GUI\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
fi
if test -z "${WINDRV_TRUE}" && test -z "${WINDRV_FALSE}"; then
  as_fn_error $? "conditional \"WINDRV\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
fi
if test -z "${MSYS_TRUE}" && test -z "${MSYS_FALSE}"; then
  as_fn_error $? "conditional \"MSYS\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
fi
if test -z "${VCPP_TRUE}" && test -z "${VCPP_FALSE}"; then
  as_fn_error $? "conditional \"VCPP\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
fi
if test -z "${POCC_TRUE}" && test -z "${POCC_FALSE}"; then
  as_fn_error $? "conditional \"POCC\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
fi
if test -z "${BORLANDC_TRUE}" && test -z "${BORLANDC_FALSE}"; then
  as_fn_error $? "conditional \"BORLANDC\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
fi
if test -z "${WATCOM_C_TRUE}" && test -z "${WATCOM_C_FALSE}"; then
  as_fn_error $? "conditional \"WATCOM_C\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
fi
if test -z "${DMC_TRUE}" && test -z "${DMC_FALSE}"; then
  as_fn_error $? "conditional \"DMC\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
fi
if test -z "${MINGWGCC_TRUE}" && test -z "${MINGWGCC_FALSE}"; then
  as_fn_error $? "conditional \"MINGWGCC\" was never defined.
Usually this means the macro was only invoked conditionally." "$LINENO" 5
